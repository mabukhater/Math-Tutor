# ── Shared Supabase project (use a DEDICATED project for the math tutor) ──
SUPABASE_URL=                  # https://<ref>.supabase.co
SUPABASE_ANON_KEY=             # web app (browser-safe)
SUPABASE_SERVICE_ROLE_KEY=     # bot worker + generator + server-side web routes ONLY — never ship to the browser

# ── Telegram bot worker ──
TELEGRAM_BOT_TOKEN=
BOT_USERNAME=                  # for t.me/<BOT_USERNAME>?start=<token> deep links

# ── Offline question generator (NEVER called in the child-facing path) ──
ANTHROPIC_API_KEY=
GENERATOR_MODEL=claude-opus-4-8   # or claude-sonnet-4-6
